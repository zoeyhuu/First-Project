        <mxCell id="QIJXQ-yAKW29Jxe0ipJB-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;工单池（需求侧）&lt;/font&gt;&lt;div style=&quot;text-align: left;&quot;&gt;工单信息：&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;静态属性：工单类型（按场景区分）、工单生成位置信息...&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;时效信息：预计到达时间（ETA）、预计派发时间、预计关单时间...&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;......&lt;/div&gt;" vertex="1">
          <mxGeometry height="138" width="287" x="834" y="852" as="geometry" />
        </mxCell>
        <mxCell id="QIJXQ-yAKW29Jxe0ipJB-24" edge="1" parent="1" source="QIJXQ-yAKW29Jxe0ipJB-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;endArrow=none;endFill=0;" target="QIJXQ-yAKW29Jxe0ipJB-1">
