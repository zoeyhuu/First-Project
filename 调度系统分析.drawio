        <mxCell id="QIJXQ-yAKW29Jxe0ipJB-94" connectable="0" parent="QIJXQ-yAKW29Jxe0ipJB-93" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="&lt;font style=&quot;font-size: 7px;&quot;&gt;波次类型可对应n个作业大类&lt;br&gt;但不同波次类型对应的作业大类不能重复&lt;br&gt;即，波次类型与【作业大类集】为一一映射&lt;/font&gt;" vertex="1">
          <mxGeometry relative="1" x="-0.0888" y="-2" as="geometry">
            <mxPoint x="1" y="-9" as="offset" />
          </mxGeometry>
        </mxCell>
